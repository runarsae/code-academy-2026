# ============================================
# Idempotweet — Environment Variables
# ============================================
# Kopier til .env med:  just setup
# Alle variabler har fornuftige standardverdier for lokal utvikling.

# --- Container runtime ---
# Bytt til "podman compose" hvis du bruker Podman
COMPOSE="docker compose"

# --- Database ---
DATABASE_URL=postgresql://codeacademy:codeacademy@localhost:5432/codeacademy

# --- App (klient-side, bakes inn under bygg) ---
# Vis skjemaet for å opprette nye idems
NEXT_PUBLIC_ENABLE_IDEM_FORM=true
# Vis idems som ble lagt inn via seed-scriptet
NEXT_PUBLIC_SHOW_SEEDED_IDEMS=true

# --- GitHub ---
# Ditt GitHub-repo (org/repo), brukes av docker-compose for å pulle images fra GHCR
GITHUB_REPOSITORY=

# --- RabbitMQ (kun for Del 2 — EventDriven) ---
# Sett til true for å publisere via RabbitMQ i stedet for direkte til database
#ENABLE_RABBITMQ=false
#RABBITMQ_URL=amqp://guest:guest@localhost:5672
